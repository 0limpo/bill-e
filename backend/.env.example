# Bill-e backend — example environment variables.
# Copy to .env and fill in real values. Do NOT commit .env.

# Production gate (set to "production" on Render, leave empty in dev)
ENV=development

# Resend transactional email (https://resend.com)
# Free tier: 3000/month. Default sender works without DNS setup but
# only delivers to your own account email until you verify a domain.
RESEND_API_KEY=
RESEND_FROM=Bill-e <onboarding@resend.dev>

# SimpleAPI — emision boleta electronica DTE 39 al SII
# https://simpleapi.cl
# Compliance: Res. Exenta SII N°12/2025 (plazo 1-mar-2026)
SIMPLEAPI_API_KEY=
SIMPLEAPI_URL=https://api.simpleapi.cl/api/v1
SIMPLEAPI_RUT_EMISOR=78308501-1
SIMPLEAPI_RAZON_SOCIAL=OLIMPO SPA

# (Existing envs not listed here. Ask team for full list before deploying.)
